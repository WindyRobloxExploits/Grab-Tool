-- =====================
-- HIGHLIGHT SYSTEM
-- =====================

local function isLoosePart(part)
    if not part or not part:IsA("BasePart") then return false end
    if part.Anchored then return false end
    if not part.Parent then return false end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character and part:IsDescendantOf(p.Character) then return false end
    end
    if part:FindFirstAncestorOfClass("Tool") then return false end
    return true
end

local function addHighlight(part)
    if highlights[part] then return end
    local sel = Instance.new("SelectionBox")
    sel.Adornee = part
    sel.Color3 = Color3.fromRGB(255, 80, 0)
    sel.LineThickness = 0.04
    sel.SurfaceTransparency = 0.8
    sel.SurfaceColor3 = Color3.fromRGB(255, 140, 0)
    sel.Parent = workspace
    highlights[part] = sel
end

local function removeHighlight(part)
    if highlights[part] then
        highlights[part]:Destroy()
        highlights[part] = nil
    end
end

local function clearAllHighlights()
    for part, sel in pairs(highlights) do
        if sel then sel:Destroy() end
    end
    highlights = {}
end

local function startScanner()
    if scanConn then return end
    local tick = 0
    scanConn = RunService.Heartbeat:Connect(function(dt)
        tick = tick + dt
        if tick < 0.5 then return end
        tick = 0
        if not toolEquipped then return end

        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end

        local current = {}
        for _, obj in ipairs(workspace:GetPartBoundsInRadius(rootPart.Position, grabRange + 20)) do
            if isLoosePart(obj) and obj ~= heldPart then
                current[obj] = true
            end
        end

        for part in pairs(current) do addHighlight(part) end
        for part in pairs(highlights) do
            if not current[part] then removeHighlight(part) end
        end
    end)
end

local function stopScanner()
    if scanConn then scanConn:Disconnect() scanConn = nil end
    clearAllHighlights()
end

