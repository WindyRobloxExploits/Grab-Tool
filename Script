-- =====================
-- CURSOR WORLD POSITION
-- =====================

local function getCursorWorldPos(screenPos)
    local unitRay = camera:ScreenPointToRay(screenPos.X, screenPos.Y)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {character, heldPart}
    params.FilterType = Enum.RaycastFilterType.Exclude

    -- Always use currentDepth so Z/X directly controls where part floats
    return unitRay.Origin + unitRay.Direction * currentDepth
end

-- =====================
-- GRAB
-- =====================

local function grabPart(part)
    if heldPart then return end
    if not isLoosePart(part) then return end

    heldPart = part
    currentDepth = holdDepth
    originalCollision[part] = part.CanCollide
    part.CanCollide = false
    removeHighlight(part)

    if bodyGyro then bodyGyro:Destroy() end
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    bodyGyro.P = 1e5
    bodyGyro.D = 500
    bodyGyro.CFrame = part.CFrame
    bodyGyro.Parent = part

    if bodyVelocity then bodyVelocity:Destroy() end
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Velocity = Vector3.zero
    bodyVelocity.MaxForce = Vector3.new(1e8, 1e8, 1e8)
    bodyVelocity.P = 1e5
    bodyVelocity.Parent = part

    -- Cache gravity compensation (calculated once, not every frame)
    local gravityComp = workspace.Gravity * part:GetMass() * 0.016

    if heartbeatConn then heartbeatConn:Disconnect() end
    heartbeatConn = RunService.Heartbeat:Connect(function()
        if not heldPart or not bodyVelocity or not bodyVelocity.Parent then
            if heartbeatConn then heartbeatConn:Disconnect() heartbeatConn = nil end
            return
        end

        -- Z / X depth control (keyboard or mobile buttons)
        local zDown = UserInputService:IsKeyDown(Enum.KeyCode.Z) or mobilePullClose
        local xDown = UserInputService:IsKeyDown(Enum.KeyCode.X) or mobilePushFar
        if zDown then
            currentDepth = math.max(depthMin, currentDepth - depthStep)
        elseif xDown then
            currentDepth = math.min(depthMax, currentDepth + depthStep)
        end

        -- Chase cursor target
        local screenPos = isMobile and touchPos or Vector2.new(mouse.X, mouse.Y)
        local targetPos = getCursorWorldPos(screenPos)
        local diff = targetPos - heldPart.Position
        local dist = diff.Magnitude
        local speed = math.clamp(dist * 25, 0, 500)

        bodyVelocity.Velocity = (dist > 0.05)
            and (diff.Unit * speed + Vector3.new(0, gravityComp, 0))
            or Vector3.new(0, gravityComp, 0)
    end)

    if statusLabel then
        statusLabel.Text = "Status: Holding " .. part.Name
        statusLabel.TextColor3 = Color3.fromRGB(255, 180, 80)
    end
end

-- =====================
-- THROW
-- =====================

function throwItem()
    if not heldPart then return end
    local part = heldPart
    heldPart = nil

    if heartbeatConn then heartbeatConn:Disconnect() heartbeatConn = nil end
    if bodyVelocity  then bodyVelocity:Destroy()  bodyVelocity = nil  end
    if bodyGyro      then bodyGyro:Destroy()       bodyGyro = nil      end

    if originalCollision[part] ~= nil then
        part.CanCollide = originalCollision[part]
        originalCollision[part] = nil
    end

    currentDepth = holdDepth

    local tv = Instance.new("BodyVelocity")
    tv.Velocity = camera.CFrame.LookVector * throwForce + Vector3.new(0, throwUpForce, 0)
    tv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    tv.Parent = part
    Debris:AddItem(tv, 0.35)

    if statusLabel then
        statusLabel.Text = "Status: Idle"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    end
end

-- =====================
-- DROP
-- =====================

local function dropItem()
    if not heldPart then return end
    local part = heldPart
    heldPart = nil

    if heartbeatConn then heartbeatConn:Disconnect() heartbeatConn = nil end
    if bodyVelocity  then bodyVelocity:Destroy()  bodyVelocity = nil  end
    if bodyGyro      then bodyGyro:Destroy()       bodyGyro = nil      end

    if originalCollision[part] ~= nil then
        part.CanCollide = originalCollision[part]
        originalCollision[part] = nil
    end

    currentDepth = holdDepth

    if statusLabel then
        statusLabel.Text = "Status: Idle"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    end
end

-- =====================
-- PC INPUT
-- =====================

grabTool.Activated:Connect(function()
    if heldPart then throwItem() return end

    local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {character}
    params.FilterType = Enum.RaycastFilterType.Exclude

    local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * grabRange, params)
    if result and result.Instance and isLoosePart(result.Instance) then
        grabPart(result.Instance)
    end
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if not toolEquipped then return end

    if input.KeyCode == Enum.KeyCode.F then
        if heldPart then throwItem() end
    end

    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        dropItem()
    end
end)

-- =====================
-- MOBILE INPUT
-- =====================

if isMobile then
    local grabbing = false

    UserInputService.TouchStarted:Connect(function(touch, processed)
        if processed then return end
        if not toolEquipped then return end
        touchPos = Vector2.new(touch.Position.X, touch.Position.Y)
        if heldPart then return end

        local unitRay = camera:ScreenPointToRay(touch.Position.X, touch.Position.Y)
        local params = RaycastParams.new()
        params.FilterDescendantsInstances = {character}
        params.FilterType = Enum.RaycastFilterType.Exclude

        local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * grabRange, params)
        if result and result.Instance and isLoosePart(result.Instance) then
            grabbing = true
            grabPart(result.Instance)
        end
    end)

    UserInputService.TouchMoved:Connect(function(touch, processed)
        touchPos = Vector2.new(touch.Position.X, touch.Position.Y)
    end)

    UserInputService.TouchEnded:Connect(function(touch, processed)
        if grabbing and heldPart then
            throwItem()
            grabbing = false
        end
    end)
end

